# Database (pgvector — docker compose up -d)
DATABASE_URL=postgresql://veentbot:veentbot@localhost:5434/veentbot

# Ollama (local models for embedding + LLM)
OLLAMA_BASE_URL=http://localhost:11434

# LLM provider: "ollama" (local, free) or "gemini" (cloud, free tier)
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:3b

# Gemini (optional — only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Bot config
COMPANY_NAME=Veent Tix
THRESHOLD_EXACT_MATCH=0.78
THRESHOLD_RAG_GENERATE=0.65
THRESHOLD_SUGGEST_RELATED=0.52
CACHE_TTL_SECONDS=86400
